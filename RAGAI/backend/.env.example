# ── Google Gemini ──────────────────────────────────────────
GEMINI_API_KEY=your_google_gemini_api_key_here

# ── App Settings ───────────────────────────────────────────
APP_NAME=RAG AI Agent
APP_VERSION=1.0.0
DEBUG=false

# ── ChromaDB ───────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=rag_documents

# ── RAG Settings ───────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K_RESULTS=5
EMBEDDING_MODEL=models/text-embedding-004
CHAT_MODEL=gemini-1.5-flash

# ── API Settings ───────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:5500","null","file://"]
MAX_FILE_SIZE_MB=50
